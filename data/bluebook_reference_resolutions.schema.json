{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Cameron-Sab/IUPAC_BlueBook-corpus/data/bluebook_reference_resolutions.schema.json",
  "title": "Explicit Blue Book reference resolution overlays",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "format_version",
    "reference_occurrences_sha256",
    "source_corpus_sha256",
    "correction_overlays_sha256",
    "policy",
    "counters",
    "records",
    "corpus_sha256"
  ],
  "properties": {
    "format": { "const": "iupac-bluebook-reference-resolutions" },
    "format_version": { "const": "1.0.0" },
    "reference_occurrences_sha256": { "$ref": "#/$defs/sha256" },
    "source_corpus_sha256": { "$ref": "#/$defs/sha256" },
    "correction_overlays_sha256": { "$ref": "#/$defs/sha256" },
    "policy": { "const": "exact_occurrence_only_no_generic_parent_fallback" },
    "counters": { "$ref": "#/$defs/counters" },
    "records": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/record" }
    },
    "corpus_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[A-F0-9]{64}$" },
    "rule_id": {
      "type": "string",
      "pattern": "^P-[0-9]+(?:\\.[0-9]+)*(?:\\([a-z0-9]+\\))?$"
    },
    "occurrence_id": {
      "type": "string",
      "pattern": "^P-[0-9]+(?:\\.[0-9]+)*(?:\\([a-z0-9]+\\))?:xref:[0-9]{4,}$"
    },
    "counters": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_unresolved_occurrence_count",
        "resolution_record_count",
        "resolution_kind_counts",
        "remaining_unresolved_occurrence_count"
      ],
      "properties": {
        "raw_unresolved_occurrence_count": { "type": "integer", "minimum": 0 },
        "resolution_record_count": { "type": "integer", "minimum": 0 },
        "resolution_kind_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["source_alias", "historical_deleted_rule"],
          "properties": {
            "source_alias": { "type": "integer", "minimum": 0 },
            "historical_deleted_rule": { "type": "integer", "minimum": 0 }
          }
        },
        "remaining_unresolved_occurrence_count": { "const": 0 }
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resolution_id",
        "occurrence_id",
        "nominal_rule_id",
        "resolution_kind",
        "resolved_rule_id",
        "rationale_code",
        "correction_overlay_id",
        "reference_occurrence_sha256",
        "record_sha256"
      ],
      "properties": {
        "resolution_id": {
          "type": "string",
          "pattern": "^BBV3-XREF-RES-[0-9]{4}$"
        },
        "occurrence_id": { "$ref": "#/$defs/occurrence_id" },
        "nominal_rule_id": { "$ref": "#/$defs/rule_id" },
        "resolution_kind": {
          "enum": ["source_alias", "historical_deleted_rule"]
        },
        "resolved_rule_id": { "$ref": "#/$defs/rule_id" },
        "rationale_code": {
          "enum": [
            "nonexistent_subrule_resolved_to_exact_active_parent",
            "deleted_by_official_correction"
          ]
        },
        "correction_overlay_id": {
          "type": ["string", "null"],
          "pattern": "^BBV3-CORR-[A-F0-9]{16}$"
        },
        "reference_occurrence_sha256": { "$ref": "#/$defs/sha256" },
        "record_sha256": { "$ref": "#/$defs/sha256" }
      },
      "allOf": [
        {
          "if": { "properties": { "resolution_kind": { "const": "source_alias" } } },
          "then": {
            "properties": {
              "correction_overlay_id": { "type": "null" },
              "rationale_code": {
                "const": "nonexistent_subrule_resolved_to_exact_active_parent"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "resolution_kind": { "const": "historical_deleted_rule" }
            }
          },
          "then": {
            "properties": {
              "correction_overlay_id": {
                "type": "string",
                "pattern": "^BBV3-CORR-[A-F0-9]{16}$"
              },
              "rationale_code": { "const": "deleted_by_official_correction" }
            }
          }
        }
      ]
    }
  }
}
